    "papaparse": "^5.5.2",
    "postgres": "^3.4.5",
    "posthog-js": "^1.261.0",
    "posthog-node": "^5.8.1",
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-circle-flags": "^0.0.23",
    "react-data-grid": "7.0.0-beta.47",
    "react-day-picker": "^9.9.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.61.1",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-parallax-tilt": "^1.7.245",
    "recharts": "^3.3.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "sonner": "^1.7.4",
    "spotify-web-api-node": "^5.0.2",
    "swr": "^2.3.3",
    "tailwind-merge": "^2.6.0",
    "three": "^0.179.1",
    "three-globe": "^2.45.0",
    "tw-animate-css": "^1.3.6",
    "tweetnacl": "^1.0.3",
    "typewriter-effect": "^2.21.0",
