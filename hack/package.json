{
  "name": "platanus-hack",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo 2>&1 | tee .dev-server.log",
    "dev:kill": "pkill -f 'next dev --turbo' && rm -f .dev-server.log || echo 'No dev server running'",
    "dev:logs": "./scripts/dev-logs.sh",
    "dev:main": "npx tsx src/lib/dev/main.ts",
    "dev:test-minify": "npx dotenv-cli -e .env.local -- npx tsx src/lib/dev/test-minify-latest-game.ts",
    "email:dev": "email dev --port 3001 --dir src/emails",
    "typegen": "next typegen",
    "typecheck": "tsc --noEmit",
    "build": "node --import tsx src/lib/db/migrate.ts && next build",
    "start": "next start",
    "lint": "biome check",
    "lint:fix": "biome check --write --unsafe",
    "format": "biome format --write",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --import tsx src/lib/db/migrate.ts",
    "db:generate:migrate": "pnpm db:generate && pnpm db:migrate",
    "db:reset": "npx tsx src/lib/db/scripts/utils.ts",
    "db:reset:migrate": "pnpm db:reset && pnpm db:migrate",
    "db:seed": "npx dotenv-cli -e .env.local -- npx tsx src/lib/dev/seed.ts",
    "db:reset:seed": "pnpm db:reset && pnpm db:migrate && pnpm db:seed",
    "db:migrate:hack24-profiles": "npx dotenv-cli -e .env.local -- npx tsx src/lib/dev/migrate-hack24-profiles.ts",
    "db:import:hack25": "npx dotenv-cli -e .env.local -- npx tsx src/lib/dev/import-hack25-submissions.ts",
    "db:import:hack25:fast": "npx dotenv-cli -e .env.local -- npx tsx src/lib/dev/import-hack25-submissions-optimized.ts",
    "db:docker:start": "docker compose -f docker-compose.dev.yml --env-file .env.local up -d postgres",
    "db:docker:stop": "docker compose -f docker-compose.dev.yml --env-file .env.local down",
    "docker:build:prod:local": "docker compose --env-file .env.local --progress=plain -f docker-compose.production.yml build app migrator",
    "docker:up:prod:local": "docker compose --env-file .env.local -f docker-compose.production.yml up -d app postgres cron-ticker",
    "db:psql": "npx tsx src/lib/db/scripts/psql.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:check": "drizzle-kit check",
    "db:up": "drizzle-kit up",
    "db:production:dump": "npx tsx src/lib/dev/db-dump.ts",
    "db:production:restore": "npx tsx src/lib/dev/db-restore.ts",
    "db:production:dump-restore": "pnpm db:production:dump && pnpm db:production:restore",
    "knip": "knip",
    "knip:production": "knip --production",
    "knip:fix": "knip --fix",
    "knip:fix-exports": "knip --fix --fix-type exports,types"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.998.0",
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
