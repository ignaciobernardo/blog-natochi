    "@types/react-dom": "^18.3.5",
    "@types/spotify-web-api-node": "^5.0.11",
    "baseline-browser-mapping": "^2.10.0",
    "drizzle-kit": "^0.25.0",
    "knip": "^5.62.0",
    "lefthook": "^1.12.2",
    "postcss": "^8.5.6",
    "postcss-load-config": "^6.0.1",
