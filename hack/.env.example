# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
BETTER_AUTH_SECRET=****

# Better Auth - Base URL for your application
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth - GitHub OAuth (for hacker login)
# Get from: https://github.com/settings/developers
GITHUB_CLIENT_ID=****
GITHUB_CLIENT_SECRET=****

# Discord OAuth & Bot Configuration
# OAuth App: https://discord.com/developers/applications
# Required OAuth scopes: identify, guilds.join
DISCORD_CLIENT_ID=****
DISCORD_CLIENT_SECRET=****
DISCORD_REDIRECT_URI=http://localhost:3000/api/discord/callback
# Bot token from the Bot section in Discord Developer Portal
DISCORD_BOT_TOKEN=****
# Your Discord server (guild) ID
DISCORD_GUILD_ID=****
# Channel ID where welcome messages will be sent
DISCORD_WELCOME_CHANNEL_ID=****
# Role names (will be fetched from Discord API)
DISCORD_HACKER_ROLE_NAME=****

# GitHub API Token (for accessing GitHub API)
# Get from: https://github.com/settings/tokens
# Required for syncing arcade games from forks
GITHUB_TOKEN=****

# GitHub Proxy URL (for rate limit protection)
GITHUB_PROXY_URL=http://localhost:8080

# Default arcade game cover SHA256 hash
# Used to avoid storing the default cover image in the database
# Generate with: echo -n "base64_cover_string" | shasum -a 256
DEFAULT_ARCADE_COVER_SHA256=****

# The following keys below are automatically created and
# added to your environment when you deploy on vercel

# Get your xAI API Key here for chat and image models: https://console.x.ai/
XAI_API_KEY=****

# Instructions to create a Vercel Blob Store here: https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# Storage provider selector: "vercel" or "s3"
STORAGE_PROVIDER=vercel

# S3 storage configuration (required when STORAGE_PROVIDER=s3)
S3_REGION=us-east-1
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=****
S3_SECRET_ACCESS_KEY=****
# Optional session token for temporary credentials
S3_SESSION_TOKEN=
# Optional custom endpoint (Cloudflare R2, MinIO, DigitalOcean Spaces, etc)
S3_ENDPOINT=
# If true, uses path-style URLs for endpoint-based storage
S3_FORCE_PATH_STYLE=false
# Optional public URL base (CDN/domain), e.g. https://cdn.example.com
S3_PUBLIC_URL_BASE=
# If true, upload with ACL public-read (only if your bucket supports ACLs)
S3_SET_PUBLIC_ACL=false

# For local development with Docker
DB_PORT=5432

# Database
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/hack_dev

# Sentry configuration for error monitoring
# Get your Sentry DSN from https://sentry.io/settings/[your-org]/projects/[your-project]/keys/
NEXT_PUBLIC_SENTRY_DSN=****

# Mailgun SMTP Configuration
# Get from Mailgun dashboard: https://app.mailgun.com/app/sending/domains
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=mailer@hm.platan.us
SMTP_PASSWORD=your-mailgun-api-key-here
DEFAULT_FROM_EMAIL="Platanus Hack <hack@platan.us>"
SEND_EMAILS_DEVELOPMENT=false
DEVELOPMENT_CATCH_ALL_ADDRESS=rafael@platan.us
NEXT_PUBLIC_POSTHOG_KEY=***

# Slack bot token and channels for notifications
# Get bot token from your Slack app's OAuth & Permissions page
SLACK_BOT_TOKEN=xoxb-****
SLACK_CHANNEL_DEV=#dev-notifications
SLACK_CHANNEL_PROD=#prod-notifications

# Tally form URL for hackathon applications
TALLY_APPLY_URL=https://tally.so/****

# Arcade game embed domain (for production iframe isolation)
NEXT_PUBLIC_ARCADE_EMBED_DOMAIN=https://arcade-embed.platan.us# PH24 role name for Platanus Hack 24 participants
DISCORD_PH24_ROLE_NAME=PH24

# Music setup

# Discord Music Bot Configuration
# Copy these to your .env.local file

# Discord Application Client ID
DISCORD_CLIENT_ID=your_discord_client_id_here

# Discord Public Key (for webhook signature verification)
DISCORD_PUBLIC_KEY=your_discord_public_key_here

# Discord Bot Token (from Discord Developer Portal)
# Note: Use the same DISCORD_BOT_TOKEN as your main Discord integration
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Guild (Server) ID
DISCORD_GUILD_ID=your_discord_guild_id_here

# Discord Music Channel ID (right-click channel → Copy ID)
DISCORD_MUSIC_CHANNEL_ID=your_music_channel_id_here

# Spotify Application Credentials (from Spotify Developer Dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Spotify Redirect URI (for OAuth callback)
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback
# Note: SPOTIFY_REFRESH_TOKEN is now stored in the database and managed automatically
# Use the admin panel to connect Spotify via OAuth: /api/spotify/auth?eventId=YOUR_EVENT_ID

# Event ID for music (UUID of the hackathon event)
MUSIC_EVENT_ID=your_event_uuid_here

# YouTube URL for project presentations video
# This URL will be used for all project video demos
PRESENTATIONS_YOUTUBE_URL=https://www.youtube.com/watch?v=****
